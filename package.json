{
  "name": "libroo-website",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=4096' nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "deploy": "CF_DEPLOY_ENV=production pnpm build && wrangler deploy --config .output/server/wrangler.json",
    "deploy:preview": "CF_DEPLOY_ENV=preview pnpm build && wrangler deploy --env preview --config .output/server/wrangler.json",
    "deploy:migrated": "pnpm db:migrate:remote && pnpm deploy",
    "deploy:preview:migrated": "pnpm db:migrate:preview && pnpm deploy:preview",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "pnpm build && wrangler d1 migrations apply DB --local --config .output/server/wrangler.json",
    "db:migrate:remote": "pnpm build && wrangler d1 migrations apply DB --remote --config .output/server/wrangler.json",
    "db:migrate:preview": "pnpm build && wrangler d1 migrations apply DB --remote --preview --config .output/server/wrangler.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.100",
    "@iconify-json/simple-icons": "^1.2.75",
    "@nuxt/content": "^3.12.0",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^0.13.2",
    "@nuxt/ui": "^4.6.0",
    "@nuxtjs/seo": "5.1.0",
    "@nuxtjs/turnstile": "1.1.2",
    "@takumi-rs/core": "^0.73.1",
    "@takumi-rs/wasm": "^0.73.1",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.78.0"
  },
  "resolutions": {
    "unimport": "4.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "vue-demi",
      "workerd"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
