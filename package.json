{
  "name": "libroo-website",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=4096' nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "deploy": "CF_DEPLOY_ENV=production pnpm build && wrangler deploy --config .output/server/wrangler.json",
    "deploy:preview": "CF_DEPLOY_ENV=preview pnpm build && wrangler deploy --env preview --config .output/server/wrangler.json",
    "deploy:migrated": "pnpm db:migrate:remote && pnpm deploy",
    "deploy:preview:migrated": "pnpm db:migrate:preview && pnpm deploy:preview",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "pnpm build && wrangler d1 migrations apply DB --local --config .output/server/wrangler.json",
    "db:migrate:remote": "pnpm build && wrangler d1 migrations apply DB --remote --config .output/server/wrangler.json",
    "db:migrate:preview": "pnpm build && wrangler d1 migrations apply DB --remote --preview --config .output/server/wrangler.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.114",
    "@iconify-json/simple-icons": "^1.2.87",
    "@nuxt/content": "^3.14.0",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^1.2.1",
    "@nuxt/ui": "^4.9.0",
    "@nuxtjs/seo": "5.3.1",
    "@nuxtjs/turnstile": "1.1.3",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.8",
    "tailwindcss": "^4.3.1",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@types/better-sqlite3": "^7.6.13",
    "@takumi-rs/core": "^1.8.7",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.105.0"
  },
  "packageManager": "pnpm@11.9.0"
}
