{
  "name": "libroo-website",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=4096' nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "deploy": "CF_DEPLOY_ENV=production pnpm build && wrangler deploy --config .output/server/wrangler.json",
    "deploy:preview": "CF_DEPLOY_ENV=preview pnpm build && wrangler deploy --env preview --config .output/server/wrangler.json",
    "deploy:migrated": "pnpm db:migrate:remote && pnpm deploy",
    "deploy:preview:migrated": "pnpm db:migrate:preview && pnpm deploy:preview",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "pnpm build && node ./scripts/prepare-wrangler-migrations.mjs && wrangler d1 migrations apply DB --local --config .output/server/wrangler.json",
    "db:migrate:remote": "pnpm build && node ./scripts/prepare-wrangler-migrations.mjs && wrangler d1 migrations apply DB --remote --config .output/server/wrangler.json",
    "db:migrate:preview": "pnpm build && node ./scripts/prepare-wrangler-migrations.mjs && wrangler d1 migrations apply DB --remote --preview --config .output/server/wrangler.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.97",
    "@iconify-json/simple-icons": "^1.2.73",
    "@nuxt/content": "^3.12.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^0.13.2",
    "@nuxt/ui-pro": "^3.3.7",
    "@nuxtjs/seo": "3.4.0",
    "@nuxtjs/turnstile": "1.1.2",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "nuxt": "^4.4.2",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.11.1"
  },
  "resolutions": {
    "unimport": "4.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "vue-demi",
      "workerd"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
